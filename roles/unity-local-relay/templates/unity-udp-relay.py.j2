#!/usr/bin/env python3
# Managed by Ansible — do not edit manually
# Bidirectional UDP relay with dynamic LAN IP detection and network change monitoring.
# Listens on all interfaces. Detects LAN IP via default route and binds outgoing
# sockets to it so Unity Intercom sees RFC 1918 source and responds.
import socket
import threading
import time
import subprocess
import logging
import sys

logging.basicConfig(
    stream=sys.stdout,
    level=logging.INFO,
    format='%(asctime)s %(levelname)s %(message)s'
)

LISTEN_PORT = {{ unity_local_relay_listen_port }}
TARGET_PORT = {{ unity_local_relay_target_port }}
SESSION_TIMEOUT = 60  # seconds of inactivity before closing session
NETWORK_POLL_INTERVAL = 15  # seconds between LAN IP checks


def get_lan_ip():
    """Return the primary LAN IP by finding the default route interface.
    Excludes loopback and Tailscale (utun*) interfaces."""
    try:
        route = subprocess.run(
            ['route', '-n', 'get', 'default'],
            capture_output=True, text=True
        )
        iface = None
        for line in route.stdout.splitlines():
            if 'interface:' in line:
                iface = line.split()[-1].strip()
                break
        if not iface:
            return None
        ip_result = subprocess.run(
            ['ipconfig', 'getifaddr', iface],
            capture_output=True, text=True
        )
        ip = ip_result.stdout.strip()
        return ip if ip else None
    except Exception as e:
        logging.warning(f"get_lan_ip failed: {e}")
        return None


current_lan_ip = get_lan_ip()
logging.info(f"Starting relay on 0.0.0.0:{LISTEN_PORT}, LAN IP={current_lan_ip}, target=*:{TARGET_PORT}")

sessions = {}
sessions_lock = threading.Lock()

server = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
server.bind(('0.0.0.0', LISTEN_PORT))


def forward_from_target(client_addr, proxy_sock):
    """Background thread: forward Unity Intercom responses back to the remote client."""
    while True:
        try:
            data, _ = proxy_sock.recvfrom(65536)
            server.sendto(data, client_addr)
            with sessions_lock:
                if client_addr in sessions:
                    sessions[client_addr] = (proxy_sock, time.time())
        except OSError:
            break


def get_or_create_session(client_addr, lan_ip):
    with sessions_lock:
        if client_addr in sessions:
            sock, _ = sessions[client_addr]
            sessions[client_addr] = (sock, time.time())
            return sock
        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        if lan_ip:
            try:
                sock.bind((lan_ip, 0))
            except OSError as e:
                logging.warning(f"Could not bind outgoing socket to {lan_ip}: {e}")
        sessions[client_addr] = (sock, time.time())
        threading.Thread(target=forward_from_target,
                         args=(client_addr, sock), daemon=True).start()
        return sock


def monitor_network():
    """Detect LAN IP changes and clear sessions so they rebind with new source IP."""
    global current_lan_ip
    while True:
        time.sleep(NETWORK_POLL_INTERVAL)
        new_ip = get_lan_ip()
        if new_ip and new_ip != current_lan_ip:
            logging.info(f"Network change detected: {current_lan_ip} -> {new_ip}, clearing all sessions")
            current_lan_ip = new_ip
            with sessions_lock:
                for sock, _ in sessions.values():
                    try:
                        sock.close()
                    except OSError:
                        pass
                sessions.clear()
        # Prune stale sessions
        now = time.time()
        with sessions_lock:
            stale = [addr for addr, (sock, ts) in sessions.items()
                     if now - ts > SESSION_TIMEOUT]
            for addr in stale:
                try:
                    sessions[addr][0].close()
                except OSError:
                    pass
                del sessions[addr]


threading.Thread(target=monitor_network, daemon=True).start()

while True:
    data, client_addr = server.recvfrom(65536)
    lan_ip = current_lan_ip
    if not lan_ip:
        logging.warning("No LAN IP available, dropping packet")
        continue
    sock = get_or_create_session(client_addr, lan_ip)
    sock.sendto(data, (lan_ip, TARGET_PORT))
